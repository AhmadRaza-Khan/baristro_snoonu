generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       Int    @id @default(autoincrement())
  name     String
  username String @unique
  password String
}

model Token {
  id          Int    @id @default(autoincrement())
  email       String @unique
  accessToken String
  expiration  DateTime
}
